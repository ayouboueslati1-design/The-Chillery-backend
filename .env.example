# =====================================================
# The Chillery Backend - Environment Variables Example
# =====================================================
# Copy this file to .env and fill in the values.

# App
APP_NAME="The Chillery API"
APP_VERSION="0.1.0"
DEBUG=False
NODE_ENV=development
SECRET_KEY=your-very-secret-key-here
ENVIRONMENT=development

# Database (PostgreSQL async URL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chillery_db

# Redis (optional for caching/sessions)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Super Admin (auto-created on first startup if not present)
SUPER_ADMIN_EMAIL=thechillery@gmail.com
SUPER_ADMIN_PASSWORD=thechillery123456

# Authorize.Net (PaymentCloud)
ANET_API_LOGIN_ID=your_api_login_id
ANET_TRANSACTION_KEY=your_transaction_key
ANET_PUBLIC_CLIENT_KEY=your_public_client_key

# Frontend-safe Authorize.Net vars (set in frontend .env.local)
# NEXT_PUBLIC_ANET_API_LOGIN_ID=your_api_login_id
# NEXT_PUBLIC_ANET_PUBLIC_CLIENT_KEY=your_public_client_key
